FROM golang:1.22-alpine AS builder
WORKDIR /app
RUN apk add --no-cache git build-base
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -o /out/mail-ingest ./cmd/mail-ingest

FROM alpine:3.20
RUN apk add --no-cache ca-certificates tzdata
WORKDIR /app
COPY --from=builder /out/mail-ingest /app/mail-ingest
EXPOSE 2525
CMD ["/app/mail-ingest"]
