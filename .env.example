# Global
COMPOSE_PROJECT_NAME=nexus-mail
TZ=Asia/Shanghai
APP_ENV=development
APP_PORT=8080
WEB_PORT=5173
API_BASE_URL=http://localhost:8080

# Database
POSTGRES_DB=nexus_mail
POSTGRES_USER=nexus_mail
POSTGRES_PASSWORD=nexus_mail_dev
POSTGRES_PORT=5432
PGBOUNCER_PORT=6432
DATABASE_URL=postgres://nexus_mail:***@pgbouncer:6432/nexus_mail?sslmode=disable&default_query_exec_mode=simple_protocol

# Redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379/0

# RabbitMQ
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_DEFAULT_USER=nexus
RABBITMQ_DEFAULT_PASS=nexus_dev
MAIL_PARSE_QUEUE=mail.parse.raw

# MinIO
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_BUCKET_RAW_MAIL=nexus-mail-raw
MINIO_BUCKET_ATTACHMENTS=nexus-mail-attachments

# JWT
JWT_SECRET=nexus-mail-dev-secret
JWT_EXPIRE_SECONDS=3600
REFRESH_EXPIRE_SECONDS=604800

# Mail ingest
POSTFIX_RELAY_HOST=mail-ingest:2525
MAIL_INGEST_PORT=2525
MAIL_INGEST_SPOOL_DIR=/var/spool/nexus-mail-ingest

# Docs
OPENAPI_ENABLED=true
